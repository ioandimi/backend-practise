generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  
  // This line tells Prisma: "A User can have many books"
  books     Book[]   
  
  createdAt DateTime @default(now())
}

// 2. OUR UPDATED BOOK MODEL
model Book {
  id        String   @id @default(cuid())
  title     String
  summary   String?
  pages     Int?
  published Boolean  @default(false)
  createdAt DateTime @default(now())

  // We are removing the old "author String" line, and replacing it with these two lines!
  // This links the Book directly to a specific User's ID.
  userId    String
  author    User     @relation(fields: [userId], references: [id])
}